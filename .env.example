# For a no-Postgres local ingestion smoke test:
# DATABASE_URL=sqlite:///./economy.db
CREATE_TABLES_ON_STARTUP=false
ENVIRONMENT=development
ALLOW_DEMO_AUTH=true
REDIS_URL=redis://localhost:6379/0
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ALLOW_DEMO_AUTH=true
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=
SUPABASE_AUDIENCE=authenticated
SUPABASE_ISSUER=
SUPABASE_SERVICE_ROLE_KEY=
EMAIL_PROVIDER=disabled
EMAIL_FROM=
RESEND_API_KEY=
SENDGRID_API_KEY=
POSTMARK_API_KEY=
STATCAN_BASE_URL=https://www150.statcan.gc.ca
BANK_OF_CANADA_BASE_URL=https://www.bankofcanada.ca/valet
WORLD_BANK_BASE_URL=https://api.worldbank.org/v2
OECD_BASE_URL=https://sdmx.oecd.org/public/rest
CMHC_BASE_URL=https://www.cmhc-schl.gc.ca
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
STORE_RAW_PAYLOADS=false
CACHE_TTL_MAP_SECONDS=21600
CACHE_TTL_LEADERBOARD_SECONDS=21600
CACHE_TTL_REGION_SUMMARY_SECONDS=3600
CACHE_TTL_SOURCE_STATUS_SECONDS=900
