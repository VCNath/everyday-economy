# Frontend public variables
NEXT_PUBLIC_API_BASE_URL=https://your-staging-api.example.com
NEXT_PUBLIC_ENVIRONMENT=staging
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ALLOW_DEMO_AUTH=false
NEXT_PUBLIC_SENTRY_DSN=

# Backend runtime
ENVIRONMENT=staging
ALLOW_DEMO_AUTH=false
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
REDIS_URL=rediss://default:PASSWORD@HOST:6379
API_BASE_URL=https://your-staging-api.example.com
FRONTEND_URL=https://your-staging-web.example.com
ALLOWED_ORIGINS=https://your-staging-web.example.com

# Supabase backend verification
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=
SUPABASE_AUDIENCE=authenticated
SUPABASE_ISSUER=
SUPABASE_SERVICE_ROLE_KEY=

# Email
EMAIL_PROVIDER=console
EMAIL_FROM=
RESEND_API_KEY=
SENDGRID_API_KEY=
POSTMARK_API_KEY=

# Source APIs
STATCAN_BASE_URL=https://www150.statcan.gc.ca
BANK_OF_CANADA_BASE_URL=https://www.bankofcanada.ca/valet
WORLD_BANK_BASE_URL=https://api.worldbank.org/v2
OECD_BASE_URL=https://sdmx.oecd.org/public/rest
CMHC_BASE_URL=https://www.cmhc-schl.gc.ca

# Runtime safety
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
STORE_RAW_PAYLOADS=false
CREATE_TABLES_ON_STARTUP=false
LOG_LEVEL=info
SENTRY_DSN=

# Cache TTLs
CACHE_TTL_MAP_SECONDS=21600
CACHE_TTL_LEADERBOARD_SECONDS=21600
CACHE_TTL_REGION_SUMMARY_SECONDS=3600
CACHE_TTL_SOURCE_STATUS_SECONDS=900
